#!/usr/bin/env node

/**
 * Drastically increased wordlists for slug generation.
 * Combines Docker's famous scientists/adjectives with expanded common lists.
 */

const adjectives = require("./adjectives");
const names = require("./names");

function generate() {
  const adj = adjectives[Math.floor(Math.random() * adjectives.length)];
  const name = names[Math.floor(Math.random() * names.length)];
  return `${adj}-${name}`;
}

// Support multiple generations via command line argument
const count = parseInt(process.argv[2], 10) || 1;

for (let i = 0; i < count; i++) {
  console.log(generate());
}
